<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="15" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.test_student_management.controllers.SignupController">
    <padding>
        <Insets bottom="30" left="30" right="30" top="30"/>
    </padding>

    <Label text="Create New Account" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

    <GridPane hgap="10" vgap="15">
        <Label text="Username:" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-font-weight: bold;"/>
        <TextField fx:id="usernameField" promptText="Choose a username" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="250"/>

        <Label text="Email:" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-font-weight: bold;"/>
        <TextField fx:id="emailField" promptText="Enter your email" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

        <Label text="Password:" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-font-weight: bold;"/>
        <PasswordField fx:id="passwordField" promptText="Choose a password" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

        <Label text="Confirm Password:" GridPane.columnIndex="0" GridPane.rowIndex="3" style="-fx-font-weight: bold;"/>
        <PasswordField fx:id="confirmPasswordField" promptText="Confirm your password" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
    </GridPane>

    <Button text="Sign Up" onAction="#handleSignup" prefWidth="150" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold;"/>

    <HBox alignment="CENTER" spacing="5">
        <Label text="Already have an account?"/>
        <Hyperlink text="Login" onAction="#handleLogin"/>
    </HBox>
</VBox>